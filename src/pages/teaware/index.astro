---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

const posts = await getCollection("teaware");
posts.sort((a: CollectionEntry<"teaware">, b: CollectionEntry<"teaware">) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Teaware | Tea_hojin Archive">
  <header class="section-header">
    <h1 class="section-title">Teawares</h1>
    <span class="section-meta">{posts.length} entries</span>
  </header>
  <PostList posts={posts} basePath="/teaware" />
</BaseLayout>
