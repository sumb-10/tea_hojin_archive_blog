---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

const posts = await getCollection("scent-notes");
posts.sort((a: CollectionEntry<"scent-notes">, b: CollectionEntry<"scent-notes">) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Scent Notes | Tea_hojin Archive">
  <header class="section-header">
    <h1 class="section-title">Scent Notes</h1>
    <span class="section-meta">{posts.length} entries</span>
  </header>
  <PostList posts={posts} basePath="/scent-notes" />
</BaseLayout>
