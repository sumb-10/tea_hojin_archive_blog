---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import GoogleMap from "../components/GoogleMap.astro";

interface Props {
  post: CollectionEntry<"tea-log">;
}

const { post } = Astro.props;
const { Content } = await post.render();
const date = post.data.date.toISOString().slice(0, 10).replaceAll("-", "/");

const tasting = post.data.tasting;
const items = tasting
  ? [
      { key: "space", label: "공간감", value: tasting.space, angle: -90 },
      { key: "density", label: "밀도감", value: tasting.density, angle: 0 },
      { key: "softness", label: "부드러움", value: tasting.softness, angle: 90 },
      { key: "clarity", label: "맑음", value: tasting.clarity, angle: 180 },
    ]
  : [];

const center = 100;
const radius = 90;

function point(value: number, angle: number) {
  const radian = (angle * Math.PI) / 180;
  const scaled = radius * (value / 10);
  return `${center + Math.cos(radian) * scaled},${center + Math.sin(radian) * scaled}`;
}

const grid = [2.5, 5, 7.5, 10].map((value) =>
  [-90, 0, 90, 180].map((angle) => point(value, angle)).join(" ")
);
const chartPoints = items.map((item) => point(item.value, item.angle)).join(" ");
const axisMin = center - radius;
const axisMax = center + radius;
---

<BaseLayout title={`${post.data.title} | Tea_hojin Archive`} description={post.data.note}>
  <article>
    <header class="article-shell tea-log-shell">
      <div class="article-meta">
        <a href="/tea-log/">TEA LOG</a>
        <span>·</span>
        <time datetime={post.data.date.toISOString()}>{date}</time>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-note">{post.data.note}</p>
      <div class="article-hero">
        <img src={post.data.image} alt={post.data.title} />
      </div>
    </header>

    {tasting && (
      <section class="tasting-panel" aria-labelledby="tasting-title">
        <div class="tasting-copy">
          <p class="tasting-eyebrow">Tasting Evaluation</p>
          <h2 id="tasting-title">향미 평가</h2>
          <p>{post.data.tastingNote ?? "10점 만점, 0.5점 단위로 기록한 오늘의 차 인상입니다."}</p>
        </div>

        <div class="radar-chart" aria-label="공간감, 밀도감, 부드러움, 맑음 향미 평가 레이더 차트">
          <svg viewBox="0 0 200 200" role="img">
            <title>Tea log tasting radar chart</title>
            {grid.map((points) => <polygon class="radar-grid" points={points} />)}
            <line class="radar-axis" x1={center} y1={axisMin} x2={center} y2={axisMax}></line>
            <line class="radar-axis" x1={axisMin} y1={center} x2={axisMax} y2={center}></line>
            <polygon class="radar-area" points={chartPoints}></polygon>
            {items.map((item) => {
              const [x, y] = point(item.value, item.angle).split(",");
              return <circle class="radar-dot" cx={x} cy={y} r="4.2"></circle>;
            })}
          </svg>
          <span class="radar-label radar-label-top">공간감</span>
          <span class="radar-label radar-label-right">밀도감</span>
          <span class="radar-label radar-label-bottom">부드러움</span>
          <span class="radar-label radar-label-left">맑음</span>
        </div>
      </section>
    )}

    <div class="article-body tea-log-body">
      <Content />
    </div>
    <GoogleMap map={post.data.map} />
  </article>
</BaseLayout>
