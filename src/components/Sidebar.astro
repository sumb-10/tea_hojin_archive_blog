---
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About Me" },
  { href: "/tea-log/", label: "Tea Log" },
  { href: "/teaware/", label: "Teawares" },
  { href: "/notes/", label: "Notes" },
];

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === "/" ? currentPath === "/" : currentPath.startsWith(normalized);
}
---

<aside class="sidebar" aria-label="Primary navigation">
  <div class="sidebar-brand">
    <a href="/" aria-label="Tea_hojin Archive home">
      <p class="sidebar-brand-title">Tea_hojin<br />Archive</p>
    </a>
  </div>
  <p class="sidebar-note">
    A personal magazine of tea,<br />
    teaware, quiet taste,<br />
    and collected notes.
  </p>
  <nav class="sidebar-nav">
    {nav.map((item) => (
      <a class:list={{ "is-active": isActive(item.href) }} href={item.href}>{item.label}</a>
    ))}
  </nav>
  <a class="sidebar-social" href="https://www.instagram.com/tea_hojin" rel="noreferrer">
    <span class="social-mark" aria-hidden="true">◎</span>
    <span>@tea_hojin</span>
  </a>
</aside>
